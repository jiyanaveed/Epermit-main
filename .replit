modules = ["nodejs-20"]
run = "cd scraper-service && node server.js & npx vite --host 0.0.0.0 --port 8080"

[nix]
channel = "stable-24_05"
packages = ["chromium", "glib", "nss", "nspr", "atk", "at-spi2-atk", "cups", "dbus", "expat", "libdrm", "libxkbcommon", "pango", "cairo", "alsa-lib", "mesa"]

[deployment]
build = ["sh", "-c", "bun install --no-frozen-lockfile && cd scraper-service && bun install --no-frozen-lockfile && cd .. && npx vite build"]
run = ["sh", "-c", "cd scraper-service && node server.js & npx vite preview --host 0.0.0.0 --port 8080"]
deploymentTarget = "cloudrun"
publicDir = "dist/public"

[[ports]]
localPort = 8080
externalPort = 80
