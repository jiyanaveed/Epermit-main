modules = ["nodejs-20", "postgresql-16"]
run = "cd scraper-service && node server.js & npx vite --host 0.0.0.0 --port 8080"

[nix]
channel = "stable-24_05"
packages = ["chromium", "glib", "nss", "nspr", "atk", "at-spi2-atk", "cups", "dbus", "expat", "libdrm", "libxkbcommon", "pango", "cairo", "alsa-lib", "mesa", "supabase-cli", "psmisc", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libX11", "at-spi2-core"]

[deployment]
build = ["sh", "-c", "bun install --no-frozen-lockfile && cd scraper-service && bun install --no-frozen-lockfile && cd .. && npx vite build"]
run = ["sh", "-c", "cd scraper-service && node server.js & npx vite preview --host 0.0.0.0 --port 8080"]
deploymentTarget = "cloudrun"
publicDir = "dist/public"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash dev.sh"
waitForPort = 5000
